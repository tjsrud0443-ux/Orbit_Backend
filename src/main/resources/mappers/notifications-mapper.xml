<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="Notifications">

	<insert id="insertProjectNoti">
		insert into Notifications values(noti_seq.nextval, #{users_id}, #{noti_type}, #{content}, 'PROJECT', #{ref_seq}, sysdate)
	</insert>
	
	<delete id="deleteProjectNotiBySeq">
		delete from notifications where ref_seq = #{ref_seq} and ref_type = 'PROJECT'
	</delete>
</mapper>
