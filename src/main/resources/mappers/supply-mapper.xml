<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="Supply">
<!--비품 관리-->
	<select id="getSupplyList" resultType="com.study.app.domains.supplies.SupplyDTO">
	    SELECT * FROM SUPPLIES ORDER BY SUPPLY_NAME
	</select>
<!--비품 신청-->
	<!--신청 정보-->
	<insert id="supplyRequest">
	    <selectKey keyProperty="req_seq" resultType="long" order="BEFORE">
	        SELECT REQ_SEQ.NEXTVAL FROM DUAL
	    </selectKey>
	    INSERT INTO SUPPLY_REQUEST VALUES (#{req_seq}, #{users_id}, SYSDATE, #{reason}, #{status})
	</insert>
	<!--신청된 비품 리스트-->
	<insert id="supplyRequestItems">
		INSERT INTO SUPPLY_REQUEST_ITEMS VALUES (S_ITEM_SEQ.NEXTVAL,#{req_seq},#{supply_seq},#{ea},#{use_type})
	</insert>
</mapper>
