<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="Approval">

	<insert id="insertDraftDocument">
		<selectKey keyProperty="doc_seq" resultType="long" order="BEFORE">
	        select doc_seq.nextval from dual
	    </selectKey>
	    
	    insert into draft_documents values (#{doc_seq}, #{title}, #{doc_type}, #{users_id}, sysdate,
	     'DRAFT', null, 0, null, sysdate, null)
	</insert>
	
	<insert id="insertApprovalLines">
		insert into approval_lines values (line_seq.nextval, #{doc_seq}, #{users_id}, #{step_order}, 
		#{status}, null, null)
	</insert>
	
	<insert id="insertReferrers">
		insert into approval_cc values (cc_seq.nextval, #{doc_seq}, #{users_id})
	</insert>
	
	<insert id="insertVacationDetail">
		insert into vacation values (vac_seq.nextval, #{doc_seq}, #{vac_type}, #{start_date}, 
		#{end_date}, #{days}, #{reason})
	</insert>
	
	<insert id="insertGeneralDetail">
		insert into general values (general_seq.nextval, #{doc_seq}, #{purpose}, #{content})
	</insert>
	
	<insert id="insertPaymentDetail">
		<selectKey keyProperty="pay_seq" resultType="long" order="BEFORE">
			select pay_seq.nextval from dual
		</selectKey>
		insert into payment values (#{pay_seq}, #{doc_seq}, #{pay_date}, #{total_amount}, #{pay_reason}, #{account_info})
	</insert>
	
	<insert id="insertPaymentItem">
		insert into payment_items values (pa_item_seq.nextval, #{pay_seq}, #{item_order}, #{item_name}, 
		#{amount}, #{note}, #{sysname}, #{oriname})
	</insert>
	
	<insert id="insertPurchaseDetail">
		<selectKey keyProperty="purchase_seq" resultType="long" order="BEFORE">
			select purchase_seq.nextval from dual
		</selectKey>
		
		insert into purchase values (#{purchase_seq}, #{doc_seq}, #{total_amount}, #{purpose}, #{vendor}, #{purchase_date})
	</insert>
	
	<insert id="insertPurchaseItem">
		insert into purchase_items values (p_item_seq.nextval, #{purchase_seq}, #{item_order}, #{item_name}, #{ea},
		 #{unit_price}, #{total_price}, #{note})
	</insert>
	
	<insert id="insertPurchaseAttachment">
		insert into purchase_attachments values (attachment_seq.nextval, #{purchase_seq}, #{oriname}, #{sysname}, sysdate)
	</insert>
</mapper>
